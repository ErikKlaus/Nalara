rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to check if the user is accessing their own data
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // SYSTEM CONFIG: Read-only for authenticated users
    match /system_config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // USERS COLLECTION
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // DECISIONS (Subcollection)
      match /decisions/{decisionId} {
        allow read, write: if isOwner(uid);

        // ANALYSES (Subcollection within decision)
        // Cloud functions can write, users can only read their own
        match /analyses/{analysisId} {
          allow read: if isOwner(uid);
          allow write: if false; 
        }
      }

      // AI USAGE LOGS (Subcollection)
      // Cloud functions only write
      match /ai_usage_logs/{logId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // REMINDERS (Subcollection)
      match /reminders/{reminderId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) 
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDismissed', 'dismissedAt', 'updatedAt']);
        allow delete: if isOwner(uid);
      }
    }
  }
}
